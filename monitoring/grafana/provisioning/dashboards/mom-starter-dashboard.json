{
  "id": null,
  "uid": "mom-starter-api-obs",
  "title": "Mom Starter API — Observability",
  "description": "Request rate, error rate (4xx/5xx), and latency percentiles (p50/p95/p99) per endpoint. Powered by Micrometer + Prometheus.",
  "tags": ["mom-starter", "api", "observability"],
  "schemaVersion": 38,
  "version": 1,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "API สถานะ (Up / Down)",
      "description": "1 = UP (Prometheus scrape สำเร็จ), 0 = DOWN",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "UP",   "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "up{job=\"mom-starter-api\"}",
          "refId": "A",
          "legendFormat": "API",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Request Rate (req/s) — ทุก endpoint รวม",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"mom-starter-api\"}[1m]))",
          "refId": "A",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error Rate 5xx (req/s)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 0.001 }
            ]
          }
        },
        "overrides": []
      },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"mom-starter-api\",status=~\"5..\"}[1m]))",
          "refId": "A",
          "legendFormat": "5xx/s"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Error Rate 4xx (req/s)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.001 }
            ]
          }
        },
        "overrides": []
      },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"mom-starter-api\",status=~\"4..\"}[1m]))",
          "refId": "A",
          "legendFormat": "4xx/s"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Rate ต่อ endpoint (req/s)",
      "description": "แยกตาม HTTP method, URI, และ status code — ดูว่าเส้นไหนถูกเรียกมากที่สุด",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"mom-starter-api\"}[1m])) by (uri, method, status)",
          "refId": "A",
          "legendFormat": "{{method}} {{uri}} [{{status}}]"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Error Rate ต่อ endpoint — 4xx และ 5xx (req/s)",
      "description": "4xx = client error (auth/validation), 5xx = server error (bug/crash)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"mom-starter-api\",status=~\"4..\"}[1m])) by (uri, method)",
          "refId": "A",
          "legendFormat": "4xx {{method}} {{uri}}"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"mom-starter-api\",status=~\"5..\"}[1m])) by (uri, method)",
          "refId": "B",
          "legendFormat": "5xx {{method}} {{uri}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Latency p50 (median) ต่อ endpoint",
      "description": "50% ของ request ตอบเร็วกว่านี้ — ดู baseline performance",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 13 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "asc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.25 },
              { "color": "red",    "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=\"mom-starter-api\"}[5m])) by (le, uri, method))",
          "refId": "A",
          "legendFormat": "p50 {{method}} {{uri}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Latency p95 ต่อ endpoint",
      "description": "95% ของ request ตอบเร็วกว่านี้ — ตรวจจับปัญหาที่เกิดบ่อยพอรู้สึกได้",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 13 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "asc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red",    "value": 1.0 }
            ]
          }
        },
        "overrides": []
      },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"mom-starter-api\"}[5m])) by (le, uri, method))",
          "refId": "A",
          "legendFormat": "p95 {{method}} {{uri}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Latency p99 ต่อ endpoint",
      "description": "99% ของ request ตอบเร็วกว่านี้ — ตรวจจับ outlier / tail latency ที่กระทบ 1% ของผู้ใช้",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 13 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "asc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1.0 },
              { "color": "red",    "value": 2.0 }
            ]
          }
        },
        "overrides": []
      },
      "datasource": { "type": "prometheus", "uid": "prometheus-ds" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"mom-starter-api\"}[5m])) by (le, uri, method))",
          "refId": "A",
          "legendFormat": "p99 {{method}} {{uri}}"
        }
      ]
    }
  ]
}
